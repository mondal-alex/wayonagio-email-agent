# ---------------------------------------------------------------------------
# Gmail OAuth
# ---------------------------------------------------------------------------
# Google OAuth client secrets (download from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=credentials.json

# Persisted OAuth token (written by `cli auth`, refreshed automatically)
GMAIL_TOKEN_PATH=token.json

# ---------------------------------------------------------------------------
# LLM provider (LiteLLM model string: "<provider>/<model>")
# ---------------------------------------------------------------------------
# Recommended for production: Gemini API (pay-per-use).
#   LLM_MODEL=gemini/gemini-2.5-flash
#
# Recommended for local/offline dev or fully self-hosted: Ollama.
#   LLM_MODEL=ollama/llama3.2
#
# If LLM_MODEL is unset but the legacy OLLAMA_MODEL is set, we fall back to
# "ollama/<OLLAMA_MODEL>" for backward compatibility.
LLM_MODEL=ollama/llama3.2

# --- Ollama-specific (used only when LLM_MODEL starts with "ollama/") -------
# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# How long Ollama keeps the model loaded in memory after a request.
# Accepts durations like "5m", "1h", "24h", "0" (unload immediately), or "-1" (never unload).
# Default "1h" avoids cold-start latency on subsequent drafts.
OLLAMA_KEEP_ALIVE=1h

# Legacy alias: if LLM_MODEL is unset, we use "ollama/<OLLAMA_MODEL>".
# OLLAMA_MODEL=llama3.2

# --- Gemini API key ---------------------------------------------------------
# Google AI Studio API key: https://aistudio.google.com/app/apikey
#
# Used in TWO places, both independent of each other:
#   1. LLM chat completion — whenever LLM_MODEL starts with "gemini/".
#   2. KB embeddings — whenever KB_EMBEDDING_MODEL starts with "gemini/",
#      which is the *default*. So even Ollama-LLM users typically still
#      need this unless they also swap embeddings to an Ollama model.
#
# In Cloud Run, set this via Secret Manager rather than a plain env var.
# GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
# Bearer token for API authentication (used by Add-on and CLI).
# Generate a strong value with: `openssl rand -base64 32`
AUTH_BEARER_TOKEN=change-me

# ---------------------------------------------------------------------------
# Scanner (automatic draft creation loop)
# ---------------------------------------------------------------------------
# Feature flag for the automatic scanner (default: disabled for manual-first rollout)
SCANNER_ENABLED=false

# Path to SQLite DB for scanner dedup state (default: scanner_state.db)
SCANNER_STATE_DB=scanner_state.db

# ---------------------------------------------------------------------------
# Knowledge base (required — Google Drive RAG grounding)
# ---------------------------------------------------------------------------
# The agent refuses to draft unless it can ground the reply in agency
# content retrieved from these Drive folders. After configuring, run
# `cli kb-ingest` to publish kb_index.sqlite, then `cli kb-doctor` to
# verify the artifact is present and healthy.

# REQUIRED. Comma-separated Drive folder IDs (or share URLs) containing the
# agency's tour descriptions, FAQ docs, templates, etc. Contents are
# chunked, embedded, and retrieved per email.
KB_RAG_FOLDER_IDS=

# Walk subfolders under each configured folder (default: true).
KB_RAG_RECURSIVE=true

# MIME allowlist. Anything not on this list is silently skipped so
# mixed-content folders are fine to point at. Defaults are reasonable.
# KB_INCLUDE_MIME_TYPES=application/pdf,application/vnd.google-apps.document,text/plain,text/markdown

# LiteLLM model string for embeddings. gemini-embedding-001 is the current GA
# Google AI Studio embedding model (3072-dim, Matryoshka — retrieval quality
# degrades gracefully if you ever truncate), free-tier generous enough for a
# travel-agency corpus. It replaces the retired text-embedding-004, which now
# returns 404 from v1beta. Requires GEMINI_API_KEY above. Swap to
# "ollama/nomic-embed-text" (and `ollama pull nomic-embed-text`) for a
# fully-offline KB.
KB_EMBEDDING_MODEL=gemini/gemini-embedding-001

# Where to publish/read KB artifacts. Set KB_GCS_URI for Cloud Run; the
# runtime downloads to /tmp on cold start. If unset, we use KB_LOCAL_DIR
# (default ./kb_artifacts/) which is fine for single-host deployments.
# KB_GCS_URI=gs://wayonagio-kb/
# KB_LOCAL_DIR=./kb_artifacts

# How many chunks to retrieve per email (default 4).
KB_TOP_K=4

# ---------------------------------------------------------------------------
# Exemplars (optional — curator-led example replies for voice/style)
# ---------------------------------------------------------------------------
# A small pool of curator-written example Q&A docs (10–50 recommended) that
# the agent injects verbatim into the prompt as an EXAMPLE RESPONSES block,
# so drafts mirror the agency's tone and structure. Orthogonal to the KB:
# the KB supplies *facts*, exemplars supply *voice*. Disabled by default;
# KB failures abort drafting, exemplar failures degrade silently.
#
# See `src/wayonagio_email_agent/exemplars/README.md` for the curator
# contract (one Doc per exemplar, no chunking, refreshed on process start).

# Comma-separated Drive folder IDs (or share URLs) containing the exemplar
# Docs. Leave unset or empty to disable the feature entirely — no Drive
# call is made and the prompt is built without the EXAMPLE RESPONSES block.
# KB_EXEMPLAR_FOLDER_IDS=

# MIME allowlist for exemplars. Defaults match the KB allowlist
# (Docs / PDF / txt / md). Override only if you have a reason to diverge.
# KB_EXEMPLAR_INCLUDE_MIME_TYPES=application/pdf,application/vnd.google-apps.document,text/plain,text/markdown

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
